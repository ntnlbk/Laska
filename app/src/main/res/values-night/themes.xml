<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Laska" parent="Theme.Material3.DayNight.NoActionBar">\
        <item name="android:statusBarColor">@android:color/transparent</item>\
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Laska" parent="Base.Theme.Laska" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/main_background</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Laska</item>
    </style>
</resources>