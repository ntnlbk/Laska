<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="342dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/menu_options_background"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingBottom="40dp">

    <TextView
        android:id="@+id/russian_lang_option"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Русский язык"
        android:fontFamily="@font/inter"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:width="308dp"
        android:layout_margin="40dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
    android:id="@+id/belarusian_lang_option"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Беларуская мова"
    android:fontFamily="@font/inter"
    android:textColor="#FFFFFF"
    android:textSize="16sp"
    android:width="308dp"
    android:layout_margin="20dp"
    android:layout_marginHorizontal="16dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/russian_lang_option"
        android:layout_marginBottom="40dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>