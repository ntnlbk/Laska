<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="342dp"
    android:layout_height="wrap_content"
    android:background="@drawable/menu_options_background_light"
    android:paddingBottom="44dp"
    android:layout_marginHorizontal="30dp">

    <TextView
        android:id="@+id/small_letter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="44dp"
        android:fontFamily="@font/inter"
        android:text="A"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:maxHeight="6dp"
        android:layout_marginTop="44dp"
        android:max="40"
        android:min="10"
        android:progress="0"
        android:progressDrawable="@drawable/seekbar_font_choosing_background"
        android:thumb="@drawable/seekbar_thumb_font_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/large_letter"
        app:layout_constraintStart_toEndOf="@id/small_letter"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/large_letter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/inter"
        android:text="A"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>