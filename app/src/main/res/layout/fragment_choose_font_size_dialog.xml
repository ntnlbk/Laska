<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="342dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/menu_options_background"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingBottom="40dp">

    <TextView
        android:id="@+id/small_option"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Мелкий"
        android:fontFamily="@font/inter"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:width="308dp"
        android:layout_margin="40dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/medium_option"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Средний"
        android:fontFamily="@font/inter"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:width="308dp"
        android:layout_margin="20dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/small_option"
        android:layout_marginBottom="40dp"
        />

    <TextView
        android:id="@+id/large_option"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Крупный"
        android:fontFamily="@font/inter"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:width="308dp"
        android:layout_margin="20dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/medium_option"
        android:layout_marginBottom="40dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>